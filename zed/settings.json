// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": false,
      "model": "gpt-5.4",
      "provider": "copilot_chat",
    },
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "buffer_font_family": "Guguru Sans Code 35",
  "buffer_font_size": 12,
  "collaboration_panel": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "git_panel": {
    "tree_view": true,
  },
  "icon_theme": "Catppuccin Frappé",
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "theme": "Catppuccin Frappé - No Italics",
  "ui_font_family": "Guguru Sans Code 35",
  "ui_font_size": 12,
}
